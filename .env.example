# Hardhat / deploy / verify configuration. Loaded by hardhat.config.js via dotenv.
# Copy to `.env` (gitignored) and fill in. Never commit real values.

# Sepolia RPC endpoint (Alchemy, Infura, QuickNode, ...).
SEPOLIA_RPC_URL=

# Deployer wallet private key. WARNING: this key holds your testnet ETH.
# Use a dedicated test wallet — never reuse a mainnet key here.
DEPLOYER_PRIVATE_KEY=

# Etherscan API key for `npx hardhat verify`.
# Free: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Optional: address to set as the registry minter. Defaults to deployer.
INITIAL_MINTER=

# Optional: reward token configuration.
# Set either to "0" to skip the funding step at deploy time.
REWARD_AMOUNT=10
REWARD_FUND=1000000
