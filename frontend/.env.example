# Frontend env schema. Copy to `.env.local` (gitignored) and fill in.
# CRA loads `.env.local` on both `npm start` and `npm run build`.
# In production on Vercel, set these as Project Environment Variables
# in the Vercel dashboard instead of using a file.
#
# Note: every REACT_APP_* variable is embedded in the built JS bundle
# and is therefore visible to anyone using the deployed site. Do not
# put values here that you treat as server-side secrets.

# Pinata IPFS pinning API.
REACT_APP_PINATA_API_URL=https://api.pinata.cloud/pinning

# Pinata JWT — required for `pinJSONToIPFS` calls from the browser.
REACT_APP_PINATA_JWT=

# Sepolia VinCidRegistry address (chainId 11155111). Set in Vercel UI
# for production. Leave empty locally unless `npm start` should hit Sepolia.
REACT_APP_SMART_CONTRACT_ADDRESS=

# Localhost (Hardhat) VinCidRegistry address (chainId 31337).
# Auto-populated by `npm run deploy:local` from the repo root.
REACT_APP_SMART_CONTRACT_ADDRESS_LOCAL=
