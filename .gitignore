# Node modules
node_modules/

# Build output
# Vercel runs `npm run build` from source, so the build folder does not need
# to be committed. Keep it out of git to avoid leaking REACT_APP_* values
# (e.g. PINATA_JWT) embedded in the bundle.
build/
dist/

# Hardhat — regenerated by `npx hardhat compile`
artifacts/
cache/

# Hardhat deployments: ignore local/in-memory artifacts but commit testnet/mainnet
deployments/hardhat.json
deployments/localhost.json

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/

# Environment variables
.env
.env.*.local

# Editor directories and files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db

# Misc
*.tgz
*.log
*.swp
*.swo

# Optional npm cache directory
.npm/

# Optional eslint cache
.eslintcache

# Parcel-bundler cache (if used)
.cache/

# Storybook build outputs (if used)
.out/
storybook-static/

# Local Netlify folder (if used)
.netlify/

# Mac system files
.AppleDouble
.LSOverride

# Test output
junit.xml
test-results.xml

# Yarn Integrity file
.yarn-integrity

# Next.js build output (if used)
.next/

# Svelte build output (if used)
.svelte-kit/

# Temporary files
tmp/
temp/
*.tmp

# VS Code settings history (optional)
.history/

# npm package lock (optional, if using yarn or pnpm instead)
# package-lock.json

# pnpm lock file (optional, if not using pnpm)
# pnpm-lock.yaml